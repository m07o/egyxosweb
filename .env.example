# ═══════════════════════════════════════════════════════════════
# egyxosweb / CinemaPlus — Environment Variables Template
# ═══════════════════════════════════════════════════════════════
#
# ⚠️  تنبيه أمني مهم:
#   - لا تضع قيماً حقيقية في هذا الملف.
#   - انسخ هذا الملف إلى .env واملأ القيم الحقيقية:
#     cp .env.example .env
#   - ملف .env مُستبعد من Git تلقائياً (انظر .gitignore).
#   - لا تُرسل .env أبداً إلى GitHub أو أي مستودع عام.
#
# ═══════════════════════════════════════════════════════════════


# ──────────────────────────────────────────────────────────────
# قاعدة البيانات
# ──────────────────────────────────────────────────────────────
# SQLite (تطوير محلي):
DATABASE_URL=file:./db/custom.db

# PostgreSQL / Supabase (إنتاج):
# DATABASE_URL=postgresql://user:password@host:5432/dbname
# DIRECT_URL=postgresql://user:password@host:5432/dbname


# ──────────────────────────────────────────────────────────────
# NextAuth.js — مطلوب
# ──────────────────────────────────────────────────────────────
# 🔴 مطلوب — 32 حرف على الأقل.
# توليد سلسلة عشوائية:
#   openssl rand -base64 48
# أو:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
NEXTAUTH_SECRET=

# URL التطبيق (بدون slash في النهاية):
# تطوير محلي:
NEXTAUTH_URL=http://localhost:3000
# إنتاج:
# NEXTAUTH_URL=https://your-domain.com


# ──────────────────────────────────────────────────────────────
# بيانات المدير — للـ Seed Script فقط
# ──────────────────────────────────────────────────────────────
# 🔴 تُستخدم فقط عند تشغيل: npx prisma db seed
# لا تضعها هنا في الإنتاج — استخدم:
#   ADMIN_USERNAME=admin ADMIN_PASSWORD=<strong_pass> npx prisma db seed
#
# المتطلبات:
#   ADMIN_USERNAME: 3 أحرف على الأقل
#   ADMIN_PASSWORD: 8 أحرف على الأقل، تحتوي:
#     - حرف كبير (A-Z)
#     - حرف صغير (a-z)
#     - رقم (0-9)
#     - رمز خاص (!@#$%^&*...)
ADMIN_USERNAME=
ADMIN_PASSWORD=


# ──────────────────────────────────────────────────────────────
# TMDB API (اختياري — بدونه يُستخدم بيانات وهمية)
# ──────────────────────────────────────────────────────────────
# احصل على مفتاح من: https://www.themoviedb.org/settings/api
TMDB_API_KEY=

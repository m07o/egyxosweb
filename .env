# ============================================================
# .env - متغيرات البيئة لـ egyxosweb
# ============================================================
# هذه النسخة للنشر على Supabase + Cloudflare
# ضع القيم الحقيقية مكان القيم الوهمية
# ============================================================

# ═══════════════════════════════════════════════════════════
# Supabase PostgreSQL - Connection Pooling
# هذا للـ Web App (Next.js على Cloudflare Workers)
# يستخدم Port 6543 (Supavisor Pooler) لتقليل الاتصالات
# ═══════════════════════════════════════════════════════════
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connect_timeout=15"
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].supabase.com:5432/postgres"

# ═══════════════════════════════════════════════════════════
# NextAuth.js
# ═══════════════════════════════════════════════════════════
NEXTAUTH_URL="https://egyxosweb.com"
NEXTAUTH_SECRET="CHANGE-THIS-TO-A-RANDOM-64-CHAR-STRING"

# ═══════════════════════════════════════════════════════════
# NextAuth Database Adapter (Supabase)
# ═══════════════════════════════════════════════════════════
NEXTAUTH_ADAPTER_DB="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connect_timeout=15"

# ═══════════════════════════════════════════════════════════
# TMDB API (اختياري)
# ═══════════════════════════════════════════════════════════
TMDB_API_KEY=""

# ═══════════════════════════════════════════════════════════
# Cloudflare
# ═══════════════════════════════════════════════════════════
CLOUDFLARE_ACCOUNT_ID="YOUR_CLOUDFLARE_ACCOUNT_ID"
CLOUDFLARE_API_TOKEN="YOUR_CLOUDFLARE_API_TOKEN"

# ═══════════════════════════════════════════════════════════
# التطوير المحلي
# ═══════════════════════════════════════════════════════════
# للنشر: استخدم wrangler secret put بدلاً من وضعها هنا
# wrangler secret put DATABASE_URL
# wrangler secret put NEXTAUTH_SECRET
# wrangler secret put NEXTAUTH_URL

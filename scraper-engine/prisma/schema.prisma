// ============================================================
// Prisma Schema لـ scraper-engine (نسخة مطابقة من المشروع الرئيسي)
// ============================================================
// السكرابر يتصل مباشرة بقاعدة البيانات عبر DIRECT_URL
// لأنه يحتاج اتصالات طويلة لا تناسب Connection Pooling
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

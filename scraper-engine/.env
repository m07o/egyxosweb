// ============================================================
// scraper-engine/.env - متغيرات بيئة السكرابر
// ============================================================
// ملاحظة: السكرابر يستخدم DIRECT_URL (اتصال مباشر)
// لأن عمليات الـ Scraping تحتاج اتصالات طويلة
// ولا تناسب الـ Connection Pooling (Port 6543)
// ============================================================

# Supabase - Direct Connection (بدون Pooling)
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].supabase.com:5432/postgres"

# إعدادات السكرابر
SCRAPER_DEFAULT_TIMEOUT=30000
SCRAPER_MAX_RETRIES=3
SCRAPER_DELAY_BETWEEN_REQUESTS=2000
SCRAPER_MAX_PAGES=5

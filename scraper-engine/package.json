{
  "name": "egyxosweb-scraper-engine",
  "version": "1.0.0",
  "description": "Scraper Engine المستقل لـ egyxosweb - يتصل بـ Supabase PostgreSQL ويستخرج المحتوى",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "scrape:wecima": "tsx src/index.ts --site wecima",
    "scrape:all": "tsx src/index.ts --site all",
    "scrape:once": "tsx src/index.ts --site wecima --pages 1",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "test": "tsx src/test.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.11.1",
    "prisma": "^6.11.1",
    "bcryptjs": "^2.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}

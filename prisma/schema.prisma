// ============================================================
// egyxosweb - Prisma Schema (SQLite for local dev)
// ============================================================
// Adapted from PostgreSQL/Supabase to SQLite for sandbox env

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}


// ============================================================
// جدول الأفلام المستخرجة
// ============================================================
model Movie {
  id           String   @id @default(cuid())
  title        String
  originalTitle String?
  slug         String   @unique
  overview     String?
  posterUrl    String?
  backdropUrl  String?
  releaseYear  Int?
  quality      String   @default("720p")
  rating       Float    @default(0)
  mediaType    String   @default("movie")
  site         String
  siteUrl      String?
  isPublished  Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // علاقات
  links Link[]

  @@index([mediaType])
  @@index([site])
  @@index([isPublished])
  @@index([createdAt])
}

// ============================================================
// جدول روابط المشاهدة والتحميل
// ============================================================
model Link {
  id         String   @id @default(cuid())
  movieId    String
  movie      Movie    @relation(fields: [movieId], references: [id], onDelete: Cascade)
  serverName String   @default("Server 1")
  linkType   String   @default("stream")
  quality    String   @default("720p")
  url        String
  size       String?
  season     Int?
  episode    Int?
  isActive   Boolean  @default(true)
  language   String   @default("ar")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([movieId])
  @@index([linkType])
  @@index([quality])
  @@index([isActive])
}

// ============================================================
// جدول إعدادات السكرابر
// ============================================================
model ScraperConfig {
  id        String    @id @default(cuid())
  siteId    String    @unique
  siteName  String
  baseUrl   String
  enabled   Boolean   @default(true)
  cronExpr  String?
  maxPages  Int       @default(5)
  delayMs   Int       @default(2000)
  lastRunAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

// ============================================================
// جدول سجل عمليات السكرابر
// ============================================================
model ScrapeLog {
  id           String    @id @default(cuid())
  configId     String?
  site         String
  status       String    @default("pending")
  pagesScraped Int       @default(0)
  moviesFound  Int       @default(0)
  linksFound   Int       @default(0)
  linksNew     Int       @default(0)
  errorMessage String?
  durationMs   Int?
  startedAt    DateTime  @default(now())
  finishedAt   DateTime?

  @@index([site])
  @@index([status])
  @@index([startedAt])
}

// ============================================================
// جدول المسؤولين (Admin)
// ============================================================
model Admin {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  email     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================
// جدول المستخدمين العاديين
// ============================================================
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  name          String?
  avatarUrl     String?   @default("https://placehold.co/100x100/1a1a2e/10b981?text=U")
  isBanned      Boolean   @default(false)
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  watchlist     Watchlist[]
}

// ============================================================
// جدول قائمة المتابعة (Watchlist)
// ============================================================
model Watchlist {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  linkId    String
  addedAt   DateTime @default(now())

  @@unique([userId, linkId])
  @@index([userId])
}

// ============================================================
// إعدادات الموقع (Site Settings)
// ============================================================
model SiteSettings {
  id              String   @id @default("main")
  siteName        String   @default("سينما بلس")
  siteDescription String   @default("مشاهدة وتحميل أفلام ومسلسلات")
  logoUrl         String   @default("")
  heroAutoPlay    Boolean  @default(true)
  heroInterval    Int      @default(7)
  updatedAt       DateTime @updatedAt
}

// ============================================================
// المحتوى المخصص (Custom Content)
// ============================================================
model CustomContent {
  id          String   @id @default(cuid())
  tmdbId      Int
  mediaType   String
  title       String
  arabicTitle String
  quality     String   @default("1080p")
  tags        String   @default("[]")
  featured    Boolean  @default(false)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============================================================
// سيرفرات البث (Streaming Servers)
// ============================================================
model StreamingServer {
  id        String   @id @default(cuid())
  name      String
  url       String
  isActive  Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

// ============================================================
// رسائل التواصل (Contact Messages)
// ============================================================
model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

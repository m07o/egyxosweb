# ============================================================
# .gitignore — ملفات يجب استبعادها من Git
# ============================================================
# ⚠️  يجب أن تكون هذه الملفات ملتزمة دائماً (committed)
#     لضمان عدم رفع بيانات حساسة إلى المستودع.
# ============================================================

# ═══════════════════════════════════════════════════════════
# Dependencies
# ═══════════════════════════════════════════════════════════
node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ═══════════════════════════════════════════════════════════
# Testing & Coverage
# ═══════════════════════════════════════════════════════════
/coverage

# ═══════════════════════════════════════════════════════════
# Next.js
# ═══════════════════════════════════════════════════════════
/.next/
/out/

# ═══════════════════════════════════════════════════════════
# Production Build
# ═══════════════════════════════════════════════════════════
/build
dist

# ═══════════════════════════════════════════════════════════
# 🔴 Environment Variables — حساسة جداً
# ═══════════════════════════════════════════════════════════
# لا ترفع أبداً ملفات .env إلى Git!
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
# اسمح بملف .env.example فقط (يحتوي على أسماء المتغيرات بدون قيم)
!.env.example

# ═══════════════════════════════════════════════════════════
# Database (SQLite)
# ═══════════════════════════════════════════════════════════
*.db
*.db-journal
db/

# ═══════════════════════════════════════════════════════════
# Cloudflare
# ═══════════════════════════════════════════════════════════
.wrangler/
.dev.vars

# ═══════════════════════════════════════════════════════════
# Misc
# ═══════════════════════════════════════════════════════════
.DS_Store
*.pem
Thumbs.db

# ═══════════════════════════════════════════════════════════
# Debug Logs
# ═══════════════════════════════════════════════════════════
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log
dev.log
dev.out.log
server.log

# ═══════════════════════════════════════════════════════════
# Vercel
# ═══════════════════════════════════════════════════════════
.vercel

# ═══════════════════════════════════════════════════════════
# TypeScript
# ═══════════════════════════════════════════════════════════
*.tsbuildinfo
next-env.d.ts

# ═══════════════════════════════════════════════════════════
# IDE & Editor Config
# ═══════════════════════════════════════════════════════════
.vscode/
.idea/
*.swp
*.swo
*~
.claude
.z-ai-config

# ═══════════════════════════════════════════════════════════
# Skills & Temp
# ═══════════════════════════════════════════════════════════
/skills/
test/
prompt/
